# =========================================================
# ANOTAME MICROSERVICES - ENVIRONMENT VARIABLES REFERENCE
# =========================================================

# --- BACKEND SERVICES ---
# Local dev normally uses each service's %dev datasource URL:
# identity -> localhost:5431/identity
# catalog -> localhost:5432/catalog
# sales -> localhost:5433/sales
# operations -> localhost:5434/operations
#
# In Railway, set the datasource variables separately for each backend service
# using that service's dedicated PostgreSQL database.
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://<host>:<port>/<database>
QUARKUS_DATASOURCE_USERNAME=<database-user>
QUARKUS_DATASOURCE_PASSWORD=<database-password>
APP_DEFAULT_BRANCH_ID=<default-branch-id-for-operations-service>

# Optional: frontend URL for CORS.
# QUARKUS_HTTP_CORS_ORIGINS=https://your-frontend-domain.up.railway.app

# --- FRONTEND (anotame-web) ---
# Replace these with the public domains of the deployed services.
# SvelteKit exposes only PUBLIC_* variables to browser code.

PUBLIC_IDENTITY_URL=https://identity-service-production.up.railway.app
PUBLIC_CATALOG_URL=https://catalog-service-production.up.railway.app
PUBLIC_SALES_URL=https://sales-service-production.up.railway.app
PUBLIC_OPERATIONS_URL=https://operations-service-production.up.railway.app

# --- LOCAL PGADMIN ---
PGADMIN_DEFAULT_PASSWORD=<set-a-local-admin-password>

# --- JWT KEYS (identity-service signs; all services verify) ---
# ⚠️  CRITICAL: Missing JWT keys are the cause of 500 errors on login/register endpoints.
# All four backend services (identity, catalog, sales, operations) MUST have these variables
# set in Railway before authentication will work. See SETUP_JWT_KEYS.md for full instructions.
#
# identity-service needs BOTH keys (signs + verifies).
# catalog-service, sales-service, operations-service need MP_JWT_VERIFY_PUBLICKEY only.
#
# Generate with: openssl genrsa -out privateKey.pem 2048 && openssl rsa -in privateKey.pem -pubout -out publicKey.pem
# In Railway, paste the full PEM value directly into the variable field (multi-line is supported natively).
# In local .env files, multi-line PEM values must be wrapped in double quotes as shown below.
SMALLRYE_JWT_SIGN_KEY="-----BEGIN RSA PRIVATE KEY-----
<paste full key content here>
-----END RSA PRIVATE KEY-----"
MP_JWT_VERIFY_PUBLICKEY="-----BEGIN PUBLIC KEY-----
<paste full key content here>
-----END PUBLIC KEY-----"
